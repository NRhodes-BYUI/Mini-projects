<Hosts>
  <Host xsi:type="MailHost">
    <DesktopFormFactor>
      <ExtensionPoint xsi:type="MessageReadCommandSurface">
        <OfficeTab id="TabDefault">
          <Group id="msgReadGroup">
            <Label resid="GroupName" />
            <Control xsi:type="Button" id="msgReadOpenPaneButton">
              <Label resid="TaskpaneButton.Label" />
              <Supertip>
                <Title resid="TaskpaneButton.Label" />
                <Description resid="TaskpaneButton.Tooltip" />
              </Supertip>
              <Icon>
                <bt:Image size="16" resid="Icon.16x16" />
                <bt:Image size="32" resid="Icon.32x32" />
                <bt:Image size="80" resid="Icon.80x80" />
              </Icon>
              <Action xsi:type="ShowTaskpane">
                <SourceLocation resid="Taskpane.Url" />
              </Action>
            </Control>
          </Group>
        </OfficeTab>
      </ExtensionPoint>
    </DesktopFormFactor>
  </Host>
</Hosts>

<Resources>
  <bt:Images>
    <bt:Image id="Icon.16x16" DefaultValue="https://mini-projects-gold-zeta.vercel.app/icon-16.png"/>
    <bt:Image id="Icon.32x32" DefaultValue="https://mini-projects-gold-zeta.vercel.app/icon-32.png"/>
    <bt:Image id="Icon.80x80" DefaultValue="https://mini-projects-gold-zeta.vercel.app/icon-80.png"/>
  </bt:Images>
  <bt:Urls>
    <bt:Url id="Taskpane.Url" DefaultValue="https://mini-projects-gold-zeta.vercel.app/index.html" />
  </bt:Urls>
  <bt:ShortStrings>
    <bt:String id="GroupName" DefaultValue="Smart Search" />
    <bt:String id="TaskpaneButton.Label" DefaultValue="Open Magic Search" />
  </bt:ShortStrings>
  <bt:LongStrings>
    <bt:String id="TaskpaneButton.Tooltip" DefaultValue="Click to open the AI powered search sidebar." />
  </bt:LongStrings>
</Resources>
